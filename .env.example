# Copy to .env and fill in your Commercetools credentials.
# The dashboard's staging/production toggle picks which set is used.

# ── Production ─────────────────────────────────────────────────────────────
PROD_CTP_PROJECT_KEY=
PROD_CTP_CLIENT_ID=
PROD_CTP_CLIENT_SECRET=
PROD_CTP_AUTH_URL=
PROD_CTP_API_URL=
PROD_CTP_SCOPES=
# Base URL to prefix in front of each CTProductUrlComponent slug
PROD_CT_BASE_URL=https://

# ── Staging ────────────────────────────────────────────────────────────────
STG_CTP_PROJECT_KEY=
STG_CTP_CLIENT_ID=
STG_CTP_CLIENT_SECRET=
STG_CTP_AUTH_URL=
STG_CTP_API_URL=
STG_CTP_SCOPES=
STG_CT_BASE_URL=https://

# ── Audit tool config (optional overrides) ─────────────────────────────────
# PORT=7331
# CONCURRENCY=25
# VIDEOS_DIR=./videos
